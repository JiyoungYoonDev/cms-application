# ─── Backend connection ────────────────────────────────────────────────────────
# Internal URL for the Spring Boot backend (used by Next.js rewrites, server-side only).
# In Docker/k8s, set this to the backend service name (e.g. http://backend:8081).
BACKEND_INTERNAL_URL=http://localhost:8081

# Public base URL for client-side API calls.
# Leave empty for local dev (requests go through Next.js proxy via rewrites).
# In production, set to the backend's public URL if the client calls it directly.
NEXT_PUBLIC_API_BASE_URL=

# ─── API path overrides (usually don't need to change) ─────────────────────────
NEXT_PUBLIC_API_COURSE_CATEGORIES=/api/course-categories
NEXT_PUBLIC_API_COURSES=/api/courses
NEXT_PUBLIC_API_SECTIONS=/api/course-sections
NEXT_PUBLIC_API_LECTURES=/lectures
NEXT_PUBLIC_API_LECTURES_BASE=/api/lectures
NEXT_PUBLIC_API_LECTURE_ITEMS_BASE=/api/lecture-items
